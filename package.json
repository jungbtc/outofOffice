{
  "name": "outofoffice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @outofoffice/desktop dev",
    "tauri": "node apps/desktop/node_modules/@tauri-apps/cli/tauri.js",
    "build": "pnpm --filter @outofoffice/desktop build",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest",
    "pretest:e2e": "pnpm build",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "licenses": "pnpm licenses list --prod --long > docs/dependency-licenses.txt",
    "audit": "pnpm audit --prod",
    "clean": "pnpm -r exec rimraf dist"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@playwright/test": "1.54.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@types/node": "24.0.15",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "eslint": "9.31.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "license-checker-rseidelsohn": "4.4.2",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "7.0.6",
    "vitest": "3.2.4"
  }
}
